# Prepends a directory to the path.
add_to_path() {
  export PATH="$1:$PATH"
}

export EDITOR=nvim
export LANG="en_US.UTF-8"

# for homebrew
export PATH=/opt/homebrew/sbin:$PATH
export HOMEBREW_CASK_OPTS="--appdir=/Applications"
eval "$(/opt/homebrew/bin/brew shellenv)"

# for GNU versions of tools (coreutils and sed)
export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"
export PATH="/opt/homebrew/opt/gnu-sed/libexec/gnubin:$PATH"

# for compilers to find curl
export LDFLAGS="-L/opt/homebrew/opt/curl/lib"
export CPPFLAGS="-I/opt/homebrew/opt/curl/include"

# for pkg-config to find curl
export PKG_CONFIG_PATH="/opt/homebrew/opt/curl/lib/pkgconfig"

# for zoxide (fast directory jumping)
eval "$(zoxide init zsh)"

# for node
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# Automatically switch the version of Node depending on the directory.
# Prefers `.nvmrc`, falling back to `.node-version`. This single chpwd hook
# replaces a separate `cd()` override that also switched on `.node-version`;
# the two fired together and double-switched, so they were consolidated here.
# https://github.com/nvm-sh/nvm?tab=readme-ov-file#zsh
autoload -U add-zsh-hook
load-nvmrc() {
  local nvmrc_path
  nvmrc_path="$(nvm_find_nvmrc)"

  if [ -z "$nvmrc_path" ] && [ -f .node-version ]; then
    nvmrc_path="$PWD/.node-version"
  fi

  if [ -n "$nvmrc_path" ]; then
    local nvmrc_node_version
    nvmrc_node_version=$(nvm version "$(cat "${nvmrc_path}")")

    if [ "$nvmrc_node_version" = "N/A" ]; then
      nvm install
    elif [ "$nvmrc_node_version" != "$(nvm version)" ]; then
      nvm use
    fi
  elif [ "$(nvm version)" != "$(nvm version default)" ]; then
    echo "Reverting to nvm default version"
    nvm use default
  fi
}
add-zsh-hook chpwd load-nvmrc
load-nvmrc

# for ruby
export RBENV="$HOME/.rbenv/bin"
eval "$(rbenv init -)"
export PATH=$RBENV:$PATH

# for python
export PYENV="$HOME/.pyenv/bin"
eval "$(pyenv init -)"
eval "$(pyenv virtualenv-init -)"
export PATH=$PYENV:$PATH

# for go
mkdir -p $HOME/go/bin
export GOPATH=$HOME/go
export PATH=$GOPATH/bin:$PATH

# for LaTeX (basictex)
add_to_path /Library/TeX/texbin

# for rust
add_to_path $HOME/.cargo/bin

# for android
export ANDROID_HOME=$HOME/Library/Android/sdk
add_to_path $ANDROID_HOME/emulator
add_to_path $ANDROID_HOME/platform-tools
add_to_path $ANDROID_HOME/tools
add_to_path $ANDROID_HOME/tools/bin
add_to_path $ANDROID_HOME/cmdline-tools/latest/bin

# for java (for android)
export JAVA_HOME=$(brew --prefix openjdk@17)
add_to_path $JAVA_HOME/bin

# for dart and flutter
add_to_path $HOME/.pub-cache/bin
[[ -f ~/.dart-cli-completion/zsh-config.zsh ]] && . ~/.dart-cli-completion/zsh-config.zsh || true

# export FLUTTER="$HOME/Developer/flutter/bin"
# export PATH=$FLUTTER:$PATH

# for bun
export BUN_INSTALL="$HOME/.bun"
add_to_path $BUN_INSTALL/bin
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"

# for the imsg CLI tool for sending iMessage from bots
add_to_path $HOME/Developer/imsg/bin

# for dvx (the latest `just build` lands in this dir)
add_to_path $HOME/Developer/dvx/bin

# for dotfiles
export PATH=~/bin:$PATH

##########################
# Setup the prompt for ZSH
# https://www.themoderncoder.com/add-git-branch-information-to-your-zsh-prompt/

# Load version control information
autoload -Uz vcs_info
precmd() { vcs_info }

# Format the vcs_info_msg_0_ variable
zstyle ':vcs_info:git:*' formats ' on %b'

# Set up the prompt (with git branch name)
setopt PROMPT_SUBST
PROMPT='${PWD/#$HOME/~}${vcs_info_msg_0_} $ '

# Allow the pasting of multi-line commands with comments
# which makes it easier to copy and paste code from the web
# or generated by an LLM (like ChatGPT) directly into the terminal
# without having to remove the comments.
setopt interactivecomments
